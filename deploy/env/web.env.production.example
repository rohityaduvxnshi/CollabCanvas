# → C:\apps\collabcanvas\web\.env.production  (next start loads this)
# Secrets: generate fresh at deploy time — AUTH_SECRET: openssl rand -base64 33
#          WS_JWT_SECRET: openssl rand -hex 32 (MUST equal ws-server's value)

AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Behind Caddy: fixed public origin + trust the proxy's forwarded headers.
AUTH_URL=https://collabcanvas.dash-board.in
AUTH_TRUST_HOST=true

# Email verification codes (Phase 7). Without a key, codes only appear in the
# web service's console log — set this for real signups.
RESEND_API_KEY=
EMAIL_FROM=

DATABASE_URL=postgresql://collabcanvas:<APP_DB_PASSWORD>@127.0.0.1:5432/collabcanvas

WS_JWT_SECRET=

# Baked into the client bundle at BUILD time — set before `next build`.
NEXT_PUBLIC_WS_URL=wss://collabcanvas-ws.dash-board.in

# N5: persistent dir for uploaded files (an absolute path OUTSIDE the repo,
# e.g. a dedicated data dir on the VPS).
FILE_STORAGE_DIR=
